{%- if section.blocks.size > 0 -%}
  <div
    id="announcement-bar"
    class="announcement-bar full-width"
    role="region"
    aria-label="{{ 'announcement_bar.title' | t }}"
    style="
      --announcement-bg: {{ section.settings.background_color }};
      --announcement-text: {{ section.settings.text_color }};
      --announcement-link: {{ section.settings.link_color }};
    "
  >
    <div class="announcement-bar__inner">
      {%- if section.blocks.size > 1 and section.settings.auto_rotate -%}
        {%- comment -%} Multiple announcements with auto-rotate {%- endcomment -%}
        <div class="announcement-bar__slider" data-auto-rotate data-speed="{{ section.settings.rotate_speed }}">
          {%- for block in section.blocks -%}
            <div
              class="announcement-bar__message{% if forloop.first %} is-active{% endif %}"
              {{ block.shopify_attributes }}
              role="group"
              aria-roledescription="slide"
              aria-label="{{ forloop.index }} / {{ section.blocks.size }}"
            >
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="announcement-bar__link">
                  {{ block.settings.text }}
                </a>
              {%- else -%}
                <p class="announcement-bar__text">{{ block.settings.text }}</p>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        {%- comment -%} Single announcement or no rotation {%- endcomment -%}
        {%- for block in section.blocks -%}
          <div class="announcement-bar__message is-active" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="announcement-bar__link">
                {{ block.settings.text }}
              </a>
            {%- else -%}
              <p class="announcement-bar__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .announcement-bar {
    background-color: var(--announcement-bg, #1a1a2e);
    color: var(--announcement-text, #ffffff);
    position: relative;
    z-index: 10;
    overflow: hidden;
  }

  .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.5rem 1rem;
    position: relative;
  }

  .announcement-bar__slider {
    position: relative;
    width: 100%;
    text-align: center;
    overflow: hidden;
    min-height: 1.5em;
  }

  .announcement-bar__message {
    text-align: center;
    width: 100%;
  }

  .announcement-bar__slider .announcement-bar__message {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    opacity: 0;
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }

  .announcement-bar__slider .announcement-bar__message.is-active {
    position: relative;
    top: auto;
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .announcement-bar__text,
  .announcement-bar__link {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.4;
    margin: 0;
  }

  .announcement-bar__link {
    color: var(--announcement-link, #ffffff);
    text-decoration: none;
    display: inline-block;
    position: relative;
  }

  .announcement-bar__link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: currentColor;
    opacity: 0.4;
    transition: opacity 0.3s ease;
  }

  .announcement-bar__link:hover::after {
    opacity: 1;
  }


{% endstylesheet %}

{% javascript %}
  /* Auto-rotate slider */
  (function() {
    const slider = document.querySelector('[data-auto-rotate]');
    if (!slider) return;

    const messages = slider.querySelectorAll('.announcement-bar__message');
    if (messages.length <= 1) return;

    const speed = parseInt(slider.dataset.speed, 10) || 5;
    let currentIndex = 0;

    setInterval(function() {
      messages[currentIndex].classList.remove('is-active');
      currentIndex = (currentIndex + 1) % messages.length;
      messages[currentIndex].classList.add('is-active');
    }, speed * 1000);
  })();


{% endjavascript %}

{% schema %}
{
  "name": "t:general.announcement_bar",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "t:labels.link_color",
      "default": "#e0e0ff"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:labels.auto_rotate",
      "default": true
    },
    {
      "type": "range",
      "id": "rotate_speed",
      "label": "t:labels.rotate_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },

  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:general.announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text",
          "default": "Welcome to our store"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.announcement_bar",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
