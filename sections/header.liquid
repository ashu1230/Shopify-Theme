<header class="header">
  {%- comment -%} Top row: Logo centered, icons on right {%- endcomment -%}
  <div class="header__top">
    <div class="header__top-left">
      {%- comment -%} Empty spacer to keep logo centered {%- endcomment -%}
    </div>

    <div class="header__logo">
      {%- if section.settings.logo != blank -%}
        <a href="{{ routes.root_url }}" class="header__logo-link">
          <img
            src="{{ section.settings.logo | image_url: width: 300 }}"
            alt="{{ shop.name }}"
            class="header__logo-image"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
          >
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="header__logo-link header__logo-text">
          {{ shop.name }}
        </a>
      {%- endif -%}
    </div>

    <div class="header__icons">
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a href="{{ routes.search_url }}" class="header__icon" aria-label="{{ 'search.title' | t }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="11" cy="11" r="7.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </a>

      <a href="{{ routes.cart_url }}" class="header__icon" aria-label="{{ 'cart.title' | t }}">
        {% if cart.item_count > 0 %}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>
    </div>
  </div>

  {%- comment -%} Bottom row: Navigation menu with mega menu {%- endcomment -%}
  {%- if section.settings.menu != blank -%}
    <nav class="header__nav" aria-label="Main navigation">
      <div class="header__nav-left">
        <!-- Brand Switcher (will be teleported here if not full width) -->
      </div>
      <div class="header__nav-center">
        <ul class="header__nav-list">
          {% for link in section.settings.menu.links %}
            <li class="header__nav-item{% if link.links.size > 0 %} has-mega-menu{% endif %}">
              <a
                href="{{ link.url }}"
                class="header__nav-link{% if link.active %} is-active{% endif %}"
                {% if link.links.size > 0 %}
                  aria-expanded="false"
                  aria-controls="mega-menu-{{ forloop.index }}"
                {% endif %}
              >
                {{ link.title }}
                {%- if link.links.size > 0 -%}
                  <svg class="header__nav-chevron" width="8" height="8" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
              </a>

              {%- if link.links.size > 0 -%}
                <div class="mega-menu" id="mega-menu-{{ forloop.index }}" aria-label="{{ link.title }}">
                  <div class="mega-menu__inner">
                    {%- for child_link in link.links -%}
                      <div class="mega-menu__column">
                        <a href="{{ child_link.url }}" class="mega-menu__heading">
                          {{ child_link.title }}
                        </a>

                        {%- if child_link.links.size > 0 -%}
                          <ul class="mega-menu__list">
                            {%- for grandchild_link in child_link.links -%}
                              <li>
                                <a href="{{ grandchild_link.url }}" class="mega-menu__link">
                                  {{ grandchild_link.title }}
                                </a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </div>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            </li>
          {% endfor %}
        </ul>
      </div>
      <div class="header__nav-right">
        <!-- Balance spacer for centering -->
      </div>
    </nav>
  {%- endif -%}
</header>

<script>
  (function() {
    function initHeaderSwitcher() {
      const switcher = document.querySelector('.brand-switcher');
      const dest = document.querySelector('.header__top-left');
      if (switcher && dest) {
        if (!switcher.classList.contains('brand-switcher--full-width')) {
          const existing = dest.querySelectorAll('.brand-switcher');
          existing.forEach(el => {
            if (el !== switcher) el.remove();
          });
          
          if (!dest.contains(switcher)) {
            dest.appendChild(switcher);
          }
        }
      }
    }

    initHeaderSwitcher();

    document.addEventListener('shopify:section:load', function(e) {
      if (e.target.classList.contains('brand-switcher-section')) {
        initHeaderSwitcher();
      }
    });
  })();
</script>

{% stylesheet %}
  /* ===== Header Layout ===== */
  .header {
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 100;
  }

  /* ----- Top Row: Logo + Icons ----- */
  .header__top {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 1.25rem 0;
    min-height: 4.5rem;
  }

  .header__top-left {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    padding-left: 0;
  }

  /* Logo */
  .header__logo {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .header__logo-link {
    text-decoration: none;
    color: var(--color-foreground);
    display: inline-flex;
    align-items: center;
  }

  .header__logo-text {
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .header__logo-image {
    max-height: 3rem;
    width: auto;
    object-fit: contain;
  }

  /* Icons */
  .header__icons {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.25rem;
    padding-right: 1.5rem;
  }

  .header__icons a,
  .header__icons shopify-account {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }

  .header__icons a:hover,
  .header__icons shopify-account:hover {
    opacity: 0.6;
  }

  .header__icons svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .header__cart-count {
    position: absolute;
    top: -0.4rem;
    right: -0.5rem;
    background-color: var(--color-foreground);
    color: var(--color-background);
    font-size: 0.625rem;
    font-weight: 600;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* ----- Navigation Row ----- */
  .header__nav {
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
    padding: 0.75rem 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    width: 100%;
  }

  .header__nav-left {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    padding-left: 1.5rem;
  }

  .header__nav-center {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .header__nav-right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding-right: 1.5rem;
  }

  .header__nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem 2rem;
  }

  .header__nav-item {
    margin: 0;
    position: relative;
  }

  .header__nav-link {
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0;
    position: relative;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .header__nav-chevron {
    transition: transform 0.3s ease;
    opacity: 0.5;
  }

  .header__nav-item:hover .header__nav-chevron {
    transform: rotate(180deg);
    opacity: 1;
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-foreground);
    transition: width 0.3s ease;
  }

  .header__nav-link:hover::after,
  .header__nav-link.is-active::after {
    width: 100%;
  }

  /* ===== Mega Menu ===== */
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 600px;
    background-color: var(--color-background);
    border: 1px solid rgba(0, 0, 0, 0.1);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    padding: 2rem 2.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(10px);
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
    z-index: 200;
    pointer-events: none;
  }

  /* Show mega menu on hover */
  .header__nav-item.has-mega-menu:hover .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .mega-menu__inner {
    display: flex;
    gap: 2.5rem;
  }

  .mega-menu__column {
    min-width: 140px;
  }

  .mega-menu__heading {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-foreground);
    text-decoration: none;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    transition: opacity 0.2s ease;
  }

  .mega-menu__heading:hover {
    opacity: 0.7;
  }

  .mega-menu__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mega-menu__link {
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--color-foreground);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s ease;
    display: block;
    padding: 0.125rem 0;
  }

  .mega-menu__link:hover {
    opacity: 1;
  }

  /* ----- Responsive ----- */
  @media (max-width: 768px) {
    .header__top {
      padding: 1rem 0;
      min-height: 3.5rem;
    }

    .header__logo-text {
      font-size: 1.25rem;
      letter-spacing: 0.15em;
    }

    .header__icons {
      gap: 0.75rem;
    }

    .header__nav {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding: 0.75rem 0;
    }

    .header__nav-left,
    .header__nav-center,
    .header__nav-right {
      justify-content: center;
      padding: 0;
    }

    .header__nav-list {
      gap: 0.25rem 1rem;
    }

    .header__nav-link {
      font-size: 0.6875rem;
    }

    .mega-menu {
      min-width: 100vw;
      left: 0;
      transform: translateX(0) translateY(10px);
      border-left: none;
      border-right: none;
    }

    .header__nav-item.has-mega-menu:hover .mega-menu {
      transform: translateX(0) translateY(0);
    }

    .mega-menu__inner {
      flex-wrap: wrap;
      gap: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "t:labels.logo_width",
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
