            "subheading": "<p>Experience the craft of high fashion design.</p>"
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "C2C: PRET",
            "subheading": "<p>Shop minimal and elegant summer styles.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
