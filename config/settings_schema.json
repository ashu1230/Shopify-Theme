[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      },
      {
        "type": "font_picker",
        "id": "type_secondary_font",
        "default": "work_sans_n4",
        "label": "t:general.secondary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:settings.colors",
    "settings": [
      {
        "type": "header",
        "content": "t:settings.primary_colors"
      },
      {
        "type": "color",
        "id": "color_solid_button_label",
        "default": "#FFFFFF",
        "label": "t:settings.solid_button_label",
        "info": "t:settings.solid_button_label_info"
      },
      {
        "type": "color",
        "id": "color_accent_1",
        "default": "#121212",
        "label": "t:settings.accent_1",
        "info": "t:settings.accent_1_info"
      },
      {
        "type": "color",
        "id": "color_accent_1_gradient",
        "label": "t:settings.accent_1_gradient"
      },
      {
        "type": "color",
        "id": "color_accent_2",
        "default": "#45C0B6",
        "label": "t:settings.accent_2"
      },
      {
        "type": "color",
        "id": "color_accent_2_gradient",
        "label": "t:settings.accent_2_gradient"
      },
      {
        "type": "header",
        "content": "t:settings.secondary_colors"
      },
      {
        "type": "color",
        "id": "color_text",
        "default": "#000000",
        "label": "t:settings.text",
        "info": "t:settings.text_info"
      },
      {
        "type": "color",
        "id": "color_outline_button",
        "default": "#121212",
        "label": "t:settings.outline_button",
        "info": "t:settings.outline_button_info"
      },
      {
        "type": "color",
        "id": "color_background_1",
        "default": "#FAFAF9",
        "label": "t:settings.background_1"
      },
      {
        "type": "color",
        "id": "color_background_1_gradient",
        "label": "t:settings.background_1_gradient"
      },
      {
        "type": "color",
        "id": "color_background_2",
        "default": "#6B6B6B",
        "label": "t:settings.background_2"
      },
      {
        "type": "color",
        "id": "color_background_2_gradient",
        "label": "t:settings.background_2_gradient"
      },
      {
        "type": "header",
        "content": "t:settings.product_colors"
      },
      {
        "type": "color",
        "id": "color_star_rating",
        "default": "#A27E28",
        "label": "t:settings.star_rating"
      },
      {
        "type": "color",
        "id": "color_on_sale",
        "default": "#A27E28",
        "label": "t:settings.on_sale_accent"
