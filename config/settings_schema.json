      {
        "type": "color",
        "id": "color_sold_out",
        "default": "#A27E28",
        "label": "t:settings.sold_out_badge"
      },
      {
        "type": "color",
        "id": "color_custom_badge",
        "default": "#A27E28",
        "label": "t:settings.custom_badge"
      },
      {
        "type": "header",
        "content": "t:settings.notification_colors"
      },
      {
        "type": "color",
        "id": "color_success",
        "default": "#307A07",
        "label": "t:settings.success"
      },
      {
        "type": "color",
        "id": "color_warning",
        "default": "#CC8A00",
        "label": "t:settings.warning"
      },
      {
        "type": "color",
        "id": "color_error",
        "default": "#CC0000",
        "label": "t:settings.error"
      },
      {
        "type": "header",
        "content": "t:settings.form_colors"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      },
      {
        "type": "range",
        "id": "button_corner_radius",
        "min": 0,
        "max": 40,
        "step": 1,
        "unit": "px",
        "label": "t:settings.button_corner_radius",
        "default": 0
